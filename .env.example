# Environment variables for 窮遊 API
# Copy to .env and fill in values

# ─── API Keys ──────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys (required in production)
QIONGYOU_API_KEYS=

# OpenRouteService free tier key — get one at https://openrouteservice.org
ORS_API_KEY=

# OpenRouter key — must be a real API key (starts with "sk-or-v1-"), NOT the base64 site key.
# Get a free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Rate limiting ─────────────────────────────────────────────────────────────
QIONGYOU_RATE_LIMIT_RPM=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
QIONGYOU_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Logging ───────────────────────────────────────────────────────────────────
QIONGYOU_LOG_LEVEL=INFO
